# See wiki/dotenv-docker-secret.md

# Docker image registry prefixes.
# Default (university network): harbor cache proxies — avoids rate limits.
# Outside university: set to empty to pull directly from the source registry.
# REGISTRY_PREFIX_DOCKER_HUB=
REGISTRY_PREFIX_DOCKER_HUB=harbor.pg.innopolis.university/docker-hub-cache/
# REGISTRY_PREFIX_GHCR=
REGISTRY_PREFIX_GHCR=harbor.pg.innopolis.university/ghcr-proxy/

# backend
BACKEND_NAME="Learning Management Service"
BACKEND_DEBUG=false
BACKEND_RELOAD=false
BACKEND_CORS_ORIGINS=[]
BACKEND_CONTAINER_ADDRESS=0.0.0.0
BACKEND_CONTAINER_PORT=8000
BACKEND_HOST_ADDRESS=127.0.0.1
BACKEND_HOST_PORT=42001
BACKEND_ENABLE_INTERACTIONS=true
BACKEND_ENABLE_LEARNERS=true

# postgres
POSTGRES_DB=db-lab-8
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=42004

# pgadmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_HOST_ADDRESS=127.0.0.1
PGADMIN_HOST_PORT=42003

# caddy
CADDY_CONTAINER_PORT=80

# Gateway

GATEWAY_HOST_ADDRESS=0.0.0.0
GATEWAY_HOST_PORT=42002
LMS_API_KEY=<lms-api-key>

# Autochecker API credentials for the ETL pipeline
AUTOCHECKER_API_URL=https://auche.namaz.live
AUTOCHECKER_API_LOGIN=<autochecker-api-login>
AUTOCHECKER_API_PASSWORD=<autochecker-api-password>

# Telegram Bot
BOT_TOKEN=<bot-token>

# Nanobot
NANOBOT_GATEWAY_CONTAINER_ADDRESS=0.0.0.0
NANOBOT_GATEWAY_CONTAINER_PORT=18790
NANOBOT_WEBCHAT_CONTAINER_ADDRESS=0.0.0.0
NANOBOT_WEBCHAT_CONTAINER_PORT=8765
# Set this yourself in .env.docker.secret. No default on purpose.
NANOBOT_ACCESS_KEY=
NANOBOT_WS_URL=ws://nanobot:8765

# Qwen Code API
QWEN_CODE_API_CONTAINER_ADDRESS=0.0.0.0
QWEN_CODE_API_CONTAINER_PORT=8080
QWEN_CODE_API_HOST_ADDRESS=127.0.0.1
QWEN_CODE_API_HOST_PORT=42005
QWEN_CODE_API_MODEL=coder-model
QWEN_CODE_API_LOG_LEVEL=error
QWEN_CODE_API_MAX_RETRIES=5
QWEN_CODE_API_RETRY_DELAY_MS=1000
QWEN_CODE_API_AUTH_USE=true
QWEN_CODE_API_LOG_REQUESTS=true
QWEN_CODE_API_KEY=<qwen-code-api-key>

# LLM API
LLM_API_KEY=${QWEN_CODE_API_KEY}
LLM_API_BASE_URL=http://localhost:${QWEN_CODE_API_HOST_PORT}/v1
LLM_API_MODEL=${QWEN_CODE_API_MODEL}

# victorialogs
VICTORIALOGS_HOST_ADDRESS=127.0.0.1
VICTORIALOGS_HOST_PORT=42010

# victoriatraces
VICTORIATRACES_HOST_ADDRESS=127.0.0.1
VICTORIATRACES_HOST_PORT=42011

# ---

# Constants that shouldn't be changed.
# Written here for convenient referencing in docs.
CONST_POSTGRESQL_SERVICE_NAME=postgres
CONST_POSTGRESQL_SERVER_NAME=postgres-lab-8
CONST_POSTGRESQL_DEFAULT_PORT=5432
CONST_PGADMIN_CONTAINER_PORT=80
CONST_VICTORIALOGS_CONTAINER_PORT=9428
CONST_VICTORIATRACES_CONTAINER_PORT=10428
CONST_OTEL_COLLECTOR_GRPC_PORT=4317
